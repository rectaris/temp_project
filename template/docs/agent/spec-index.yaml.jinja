version: 1

project:
  name: "[[ project_name ]]"
  slug: "[[ project_slug ]]"
  primary_language: "[[ primary_language ]]"
  planning_style: "active_backlog_checked"

default_reads:
  - docs/agent/SPEC_VALIDATION.md
  - docs/agent/SPEC_GIT_WORKFLOW.md
  - docs/agent/SPEC_FILE_MANAGEMENT.md

task_types:
  planning_docs:
    summary: Plan indexes, active tasks, backlog, checked archives, handoff docs, plan README files, or repo instructions.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_PLAN_WORKFLOW.md
    conditional:
      - path: docs/agent/SPEC_AGENT_LOGGING.md
        when: raw agent logs, run manifests, .agent-logs, .agent-artifacts, or plan-linked run evidence are in scope.
      - path: docs/agent/SPEC_CONTEXT_COMPRESSION.md
        when: context compression, Headroom, large logs, CI logs, or compressed run views are in scope.
      - path: docs/agent/SPEC_ORCHESTRATION.md
        when: helper agents, delegation, handoffs, hooks, or execution-process behavior changes.
      - path: docs/agent/SPEC_EXTERNAL_SERVICES.md
        when: MCP, Linear, graph memory, external issue sync, or external write policy changes.
      - path: docs/agent/SPEC_DECISION_AUDIT.md
        when: unstated important decisions, approach comparisons, recommendations, or material plan preflight choices are in scope.

  product_logic:
    summary: Runtime behavior, calculations, business logic, data contracts, or public APIs.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
    conditional:
      - path: docs/agent/SPEC_ENVIRONMENT.md
        when: build, runtime, hosting, generated files, or data flow changes.
      - path: docs/agent/SPEC_UI_DESIGN.md
        when: visible UI, copy, accessibility, or interaction changes.

  ui_layout:
    summary: Visible UI, layout, labels, accessibility, interaction, or screenshots.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_UI_DESIGN.md
    conditional:
      - path: docs/agent/SPEC_ENVIRONMENT.md
        when: assets, routes, static files, or hosted paths change.
      - path: docs/agent/SPEC_JAPANESE_TECH_WRITING.md
        when: Japanese UI copy, labels, help text, documentation, prompts, plans, or prose are written or edited.

  japanese_prose:
    summary: Japanese README text, documentation, plans, specs, prompts, review comments, issue text, or other prose.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_JAPANESE_TECH_WRITING.md
    conditional:
      - path: docs/agent/SPEC_UI_DESIGN.md
        when: visible UI copy, accessibility text, interaction labels, or screenshots are affected.

  environment_data_flow:
    summary: Static assets, generated data, runtime paths, package scripts, CI, or deployment config.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_ENVIRONMENT.md
    conditional:
      - path: docs/agent/CODEX_CI_AUTOFIX.md
        when: Codex CI autofix, failed-CI repair loops, GitHub Actions workflow_run automation, or CI autofix permissions change.

  orchestration_meta:
    summary: Agent workflow, helper roles, helper prompt templates, handoff policy, hooks, or process documentation.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_PLAN_WORKFLOW.md
      - docs/agent/SPEC_ORCHESTRATION.md
    conditional:
      - path: docs/agent/SPEC_DECISION_AUDIT.md
        when: decision-audit workflow, plan preflight decisions, or recommendation-analysis behavior changes.

  skill_authoring:
    summary: Codex skills, SKILL.md files, skill references, skill scripts, skill assets, or skill UI metadata.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_VALIDATION.md
      - docs/agent/SPEC_SKILL_AUTHORING.md
    conditional:
      - path: docs/agent/SPEC_EXTERNAL_SERVICES.md
        when: the skill uses MCP, Linear, graph memory, credentials, network access, or external writes.
      - path: docs/agent/SPEC_ORCHESTRATION.md
        when: the skill defines helper-agent behavior, handoffs, hooks, or delegation workflows.
      - path: docs/agent/SPEC_DECISION_AUDIT.md
        when: meaningful skill trigger, storage, validation, lifecycle, security, or generated-artifact boundary choices remain open.

  decision_audit:
    summary: Unstated important decisions, missing decision analysis, approach comparisons, or recommendations with reasons.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_DECISION_AUDIT.md
    conditional:
      - path: docs/agent/SPEC_PLAN_WORKFLOW.md
        when: the audit affects active plans, backlog plans, checked records, handoffs, or plan lifecycle files.
      - path: docs/agent/SPEC_AGENT_LOGGING.md
        when: the full audit is stored or linked through raw logs, run manifests, or .agent-logs.
      - path: docs/agent/SPEC_CONTEXT_COMPRESSION.md
        when: large logs, Headroom, compressed views, or context-size reduction are part of the decision.

  external_services:
    summary: MCP, Linear, graph memory, external issue sync, or external write policy.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_EXTERNAL_SERVICES.md
    conditional:
      - path: docs/agent/SPEC_PLAN_WORKFLOW.md
        when: external service state is linked to plan lifecycle files.

  agent_logging:
    summary: Local raw agent logs, run manifests, redaction reports, compressed views, or large agent artifacts.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_AGENT_LOGGING.md
    conditional:
      - path: docs/agent/SPEC_CONTEXT_COMPRESSION.md
        when: large logs, Headroom, compressed views, or context-size reduction are in scope.
      - path: docs/agent/SPEC_PLAN_WORKFLOW.md
        when: logs are linked from active or checked plans.

  context_compression:
    summary: Optional compression of large logs or artifacts, including Headroom-backed derived views.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_AGENT_LOGGING.md
      - docs/agent/SPEC_CONTEXT_COMPRESSION.md
    conditional: []

usually_unneeded:
  - path: docs/agent/SPEC_ORCHESTRATION.md
    unless: orchestration, handoff, hook, or delegation behavior is in scope.
  - path: docs/agent/SPEC_ENVIRONMENT.md
    unless: environment, generated files, static paths, CI, or deployment behavior is in scope.
  - path: docs/agent/SPEC_UI_DESIGN.md
    unless: visible UI, copy, accessibility, or interaction behavior is in scope.
  - path: docs/agent/SPEC_EXTERNAL_SERVICES.md
    unless: MCP, Linear, graph memory, external issue sync, or external write behavior is in scope.
  - path: docs/agent/SPEC_JAPANESE_TECH_WRITING.md
    unless: Japanese prose, UI copy, documentation, prompts, plans, issues, or review text is in scope.
  - path: docs/agent/CODEX_CI_AUTOFIX.md
    unless: CI autofix, GitHub Actions failure repair, Codex automation, or autofix permissions are in scope.
  - path: docs/agent/SPEC_AGENT_LOGGING.md
    unless: raw agent logs, run manifests, redaction reports, .agent-logs, or .agent-artifacts are in scope.
  - path: docs/agent/SPEC_CONTEXT_COMPRESSION.md
    unless: large logs, context compression, Headroom, or compressed derived views are in scope.
  - path: docs/agent/SPEC_DECISION_AUDIT.md
    unless: unstated decisions, approach recommendations, or plan preflight choices are in scope.
  - path: docs/agent/SPEC_SKILL_AUTHORING.md
    unless: Codex skills, SKILL.md, skill references, skill scripts, skill assets, or skill metadata are in scope.

rules:
  - Start with default_reads plus the matching route's required list.
  - When a task crosses categories, union required entries first.
  - Read conditional entries only when their when rule matches.
  - Treat usually_unneeded files as opt-in.
  - Do not sweep all docs/agent files for normal startup.
  - Keep README files human-facing; agent-facing operational policy belongs in docs/agent.
  - Treat external-service modules as optional unless SPEC_EXTERNAL_SERVICES explicitly enables them.
  - Apply SPEC_JAPANESE_TECH_WRITING to Japanese prose without requiring an installed external skill.
  - Apply SPEC_SKILL_AUTHORING when creating, updating, vendoring, or reviewing Codex skills.
  - Do not compress AGENTS.md, docs/agent files, validation policy, or security policy; read normative instructions directly.
  - Use raw-log manifests, search, excerpts, and optional compression to decide whether large logs should enter context.
  - Use decision audit before non-trivial active-plan creation or material plan updates when meaningful choices remain open.
