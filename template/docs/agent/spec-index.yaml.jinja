version: 1

project:
  name: "[[ project_name ]]"
  slug: "[[ project_slug ]]"
  primary_language: "[[ primary_language ]]"
  planning_style: "[[ planning_style ]]"

default_reads:
  - docs/agent/SPEC_VALIDATION.md
  - docs/agent/SPEC_GIT_WORKFLOW.md
  - docs/agent/SPEC_FILE_MANAGEMENT.md

task_types:
  planning_docs:
    summary: Plan indexes, active tasks, backlog, checked archives, handoff docs, plan README files, or repo instructions.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_PLAN_WORKFLOW.md
    conditional:
      - path: docs/agent/SPEC_ORCHESTRATION.md
        when: helper agents, delegation, handoffs, hooks, or execution-process behavior changes.
      - path: docs/agent/SPEC_EXTERNAL_SERVICES.md
        when: MCP, Linear, graph memory, external issue sync, or external write policy changes.

  product_logic:
    summary: Runtime behavior, calculations, business logic, data contracts, or public APIs.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
    conditional:
      - path: docs/agent/SPEC_ENVIRONMENT.md
        when: build, runtime, hosting, generated files, or data flow changes.
      - path: docs/agent/SPEC_UI_DESIGN.md
        when: visible UI, copy, accessibility, or interaction changes.

  ui_layout:
    summary: Visible UI, layout, labels, accessibility, interaction, or screenshots.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_UI_DESIGN.md
    conditional:
      - path: docs/agent/SPEC_ENVIRONMENT.md
        when: assets, routes, static files, or hosted paths change.

  environment_data_flow:
    summary: Static assets, generated data, runtime paths, package scripts, CI, or deployment config.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_ENVIRONMENT.md
    conditional: []

  orchestration_meta:
    summary: Agent workflow, helper roles, helper prompt templates, handoff policy, hooks, or process documentation.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_PLAN_WORKFLOW.md
      - docs/agent/SPEC_ORCHESTRATION.md
    conditional: []

  external_services:
    summary: MCP, Linear, graph memory, external issue sync, or external write policy.
    required:
      - docs/agent/SPEC_DEVELOPMENT_FLOW.md
      - docs/agent/SPEC_EXTERNAL_SERVICES.md
    conditional:
      - path: docs/agent/SPEC_PLAN_WORKFLOW.md
        when: external service state is linked to plan lifecycle files.

usually_unneeded:
  - path: docs/agent/SPEC_ORCHESTRATION.md
    unless: orchestration, handoff, hook, or delegation behavior is in scope.
  - path: docs/agent/SPEC_ENVIRONMENT.md
    unless: environment, generated files, static paths, CI, or deployment behavior is in scope.
  - path: docs/agent/SPEC_UI_DESIGN.md
    unless: visible UI, copy, accessibility, or interaction behavior is in scope.
  - path: docs/agent/SPEC_EXTERNAL_SERVICES.md
    unless: MCP, Linear, graph memory, external issue sync, or external write behavior is in scope.

rules:
  - Start with default_reads plus the matching route's required list.
  - When a task crosses categories, union required entries first.
  - Read conditional entries only when their when rule matches.
  - Treat usually_unneeded files as opt-in.
  - Do not sweep all docs/agent files for normal startup.
  - Keep README files human-facing; agent-facing operational policy belongs in docs/agent.
  - Treat external-service modules as optional unless SPEC_EXTERNAL_SERVICES explicitly enables them.
